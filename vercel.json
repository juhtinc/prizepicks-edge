{
  "version": 2,
  "functions": {
    "api/*.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/lore?route=cron-lore&workflow=analytics",              "schedule": "0 1 * * 1"  },
    { "path": "/api/lore?route=cron-lore&workflow=weekly-batch&batch=A",   "schedule": "0 2 * * 1"  },
    { "path": "/api/lore?route=cron-lore&workflow=auto-start",            "schedule": "0 11 * * *" },
    { "path": "/api/lore?route=cron-lore&workflow=performance-check",     "schedule": "0 15 * * *" },
    { "path": "/api/lore?route=cron-lore&workflow=comments",              "schedule": "0 14 * * *" },
    { "path": "/api/lore?route=cron-lore&workflow=auto-pin",              "schedule": "0 3 * * *"  }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ]
}
