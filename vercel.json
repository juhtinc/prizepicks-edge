{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron",
      "schedule": "0 2 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ]
}
