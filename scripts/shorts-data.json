ight":"800","font_size":48,"fill_color":"#F5A623","x_alignment":"50%","width":"70%","x":"43%","y":"42%","shadow_color":"rgba(0,0,0,1)","shadow_blur":16,"line_height":"135%"},{"type":"text","track":6,"time":15.42,"duration":4.37,"text":"And in 1958, he dropped 50 points in the clinching","font_family":"Montserrat","font_weight":"800","font_size":48,"fill_color":"#F5A623","x_alignment":"50%","width":"70%","x":"43%","y":"42%","shadow_color":"rgba(0,0,0,1)","shadow_blur":16,"line_height":"135%"},{"type":"text","track":6,"time":19.58,"duration":1.03,"text":"Finals game.","font_family":"Montserrat","font_weight":"800","font_size":48,"fill_color":"#ffffff","x_alignment":"50%","width":"70%","x":"43%","y":"42%","shadow_color":"rgba(0,0,0,1)","shadow_blur":16,"line_height":"135%"},{"type":"text","track":6,"time":20.42,"duration":1.45,"text":"That's a legend.","font_family":"Montserrat","font_weight":"800","font_size":48,"fill_color":"#F5A623","x_alignment":"50%","width":"70%","x":"43%","y":"42%","shadow_color":"rgba(0,0,0,1)","shadow_blur":16,"line_height":"135%"},{"type":"text","track":6,"time":21.67,"duration":1.45,"text":"But the St.","font_family":"Montserrat","font_weight":"800","font_size":48,"fill_color":"#ffffff","x_alignment":"50%","width":"70%","x":"43%","y":"42%","shadow_color":"rgba(0,0,0,1)","shadow_blur":16,"line_height":"135%"},{"type":"text","track":6,"time":22.92,"duration":4.37,"text":"Louis Hawks moved, the footage faded, and history quietly closed","font_family":"Montserrat","font_weight":"800","font_size":48,"fill_color":"#ffffff","x_alignment":"50%","width":"70%","x":"43%","y":"42%","shadow_color":"rgba(0,0,0,1)","shadow_blur":16,"line_height":"135%"},{"type":"text","track":6,"time":27.08,"duration":1.03,"text":"the door.","font_family":"Montserrat","font_weight":"800","font_size":48,"fill_color":"#ffffff","x_alignment":"50%","width":"70%","x":"43%","y":"42%","shadow_color":"rgba(0,0,0,1)","shadow_blur":16,"line_height":"135%"},{"type":"text","track":6,"