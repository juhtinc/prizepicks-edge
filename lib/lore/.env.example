# === ColdVault Pipeline (internal codename: sports-lore) ===
# Required variables are marked [REQUIRED], optional ones are marked [OPTIONAL]

# [REQUIRED] Already configured in main PrizePicks app
ANTHROPIC_API_KEY=
KV_REST_API_URL=
KV_REST_API_TOKEN=
CRON_SECRET=

# [REQUIRED] YouTube Data API + Analytics (OAuth2)
YOUTUBE_API_KEY=
YOUTUBE_ACCESS_TOKEN=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_CHANNEL_ID=

# [REQUIRED] Creatomate (video rendering + thumbnails)
CREATOMATE_API_KEY=
CREATOMATE_THUMBNAIL_TEMPLATE_ID=
CREATOMATE_VIDEO_TEMPLATE_ID=

# [REQUIRED] ElevenLabs (text-to-speech voiceover)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# [OPTIONAL] ElevenLabs model override (default: eleven_multilingual_v2)
ELEVENLABS_MODEL_ID=

# [OPTIONAL] Pexels (stock video clips — free API key)
PEXELS_API_KEY=

# [OPTIONAL] Mubert (AI music generation — $14/mo)
MUBERT_PAT=

# [OPTIONAL] TikTok Content Posting API
TIKTOK_ACCESS_TOKEN=

# [OPTIONAL] Instagram Graph API
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# [OPTIONAL] Real footage pipeline (requires external server with yt-dlp + FFmpeg)
YT_DLP_PATH=
FFMPEG_PATH=
CLIP_STORAGE_URL=

# [OPTIONAL] Sport-specific YouTube playlists (auto-assign after upload)
PLAYLIST_NBA=
PLAYLIST_NFL=
PLAYLIST_MLB=
PLAYLIST_NHL=
PLAYLIST_Soccer=
PLAYLIST_Boxing=
PLAYLIST_Tennis=

# [OPTIONAL] Sound effect file URLs (hosted on CDN or Google Drive)
SFX_WHOOSH_SOFT=
SFX_WHOOSH_HARD=
SFX_BASS_BOOM=
SFX_BASS_DROP=
SFX_CROWD_ROAR=
SFX_CROWD_GASP=
SFX_RECORD_SCRATCH=
SFX_DRAMATIC_HIT=
SFX_SILENCE_BEAT=
